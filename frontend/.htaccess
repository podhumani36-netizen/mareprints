RewriteEngine On

# Force HTTPS + WWW
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.mareprints\.com$ [NC]
RewriteRule ^(.*)$ https://www.mareprints.com/$1 [L,R=301]

# Your existing rewrite (keep this below redirect)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]